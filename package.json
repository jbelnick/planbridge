{
  "name": "planbridge",
  "version": "0.1.0",
  "description": "A local Model Context Protocol (MCP) connector that lets ChatGPT plan over an allowlisted local dev workspace and hand the approved plan to Codex.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chatgpt",
    "codex",
    "ai-agents",
    "developer-tools",
    "typescript"
  ],
  "license": "MIT",
  "author": "Jason Belnick (https://www.jasonbelnick.com)",
  "homepage": "https://github.com/jbelnick/planbridge#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbelnick/planbridge.git"
  },
  "bugs": {
    "url": "https://github.com/jbelnick/planbridge/issues"
  },
  "private": true,
  "type": "module",
  "bin": {
    "planbridge": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "doctor": "node dist/src/cli.js doctor",
    "serve": "node dist/src/cli.js serve",
    "service:install": "scripts/planbridge-service.sh install",
    "service:logs": "scripts/planbridge-service.sh logs",
    "service:restart": "scripts/planbridge-service.sh restart",
    "service:start": "scripts/planbridge-service.sh start",
    "service:status": "scripts/planbridge-service.sh status",
    "service:stop": "scripts/planbridge-service.sh stop",
    "service:uninstall": "scripts/planbridge-service.sh uninstall",
    "start": "npm run serve",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:fixtures": "vitest run tests/integration/fixture-smoke.test.ts",
    "tunnel:doctor": "scripts/tunnel-client-profile.sh doctor",
    "tunnel:init": "scripts/tunnel-client-profile.sh init",
    "tunnel:install": "scripts/install-tunnel-client.sh",
    "tunnel:run": "scripts/tunnel-client-profile.sh run",
    "tunnel:service:install": "scripts/planbridge-tunnel-service.sh install",
    "tunnel:service:logs": "scripts/planbridge-tunnel-service.sh logs",
    "tunnel:service:restart": "scripts/planbridge-tunnel-service.sh restart",
    "tunnel:service:start": "scripts/planbridge-tunnel-service.sh start",
    "tunnel:service:status": "scripts/planbridge-tunnel-service.sh status",
    "tunnel:service:stop": "scripts/planbridge-tunnel-service.sh stop",
    "tunnel:service:uninstall": "scripts/planbridge-tunnel-service.sh uninstall",
    "tunnel:status": "scripts/tunnel-client-profile.sh status"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
